# ============================================================
# BOT DE TELEGRAM — Variables de entorno
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el .env a git.
# ============================================================

# --- Telegram ---
TELEGRAM_BOT_TOKEN=tu_token_aqui

# --- Firebase ---
FIREBASE_DB_URL=https://tu-proyecto-default-rtdb.firebaseio.com

# Opción A: ruta al archivo de credenciales descargado
FIREBASE_CREDENTIALS_PATH=./serviceAccountKey.json

# Opción B: para Railway, pega aquí el contenido del JSON en una sola línea
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# --- Entorno ---
ENVIRONMENT=production
LOG_LEVEL=INFO
